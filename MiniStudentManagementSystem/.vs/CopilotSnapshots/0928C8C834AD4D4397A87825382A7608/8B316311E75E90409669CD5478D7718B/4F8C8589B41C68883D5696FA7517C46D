using System;

namespace MiniStudentManagementSystem
{
    public partial class Logout : System.Web.UI.Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {
            // Sessiyası dayandırıb bütün sessiya məlumatlarını silin
            Session.Abandon();

            // Kukilə mövcud olarsa, onu vaxtını bitirin
            if (Request.Cookies["username"] != null)
            {
                System.Web.HttpCookie cookie = Request.Cookies["username"];
                cookie.Expires = DateTime.Now.AddDays(-1);
                Response.Cookies.Add(cookie);
            }

            // Daxil ol səhifəsinə yönləndir
            Response.Redirect("Login.aspx");
        }
    }
}
