using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Web.Script.Serialization;
using MiniStudentManagementSystem.Models;

namespace MiniStudentManagementSystem
{
    public partial class Register : System.Web.UI.Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {
            // Səhifə yükləndikdə heç bir şey etmə
        }

        protected void RegisterButton_Click(object sender, EventArgs e)
        {
            try
            {
                // TextBoxlardan qiymətləri al
                string username = UsernameTextBox.Text.Trim();
                string email = EmailTextBox.Text.Trim();
                string password = PasswordTextBox.Text.Trim();

                // Bütün sahələrin doldurulduğunu yoxla
                if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password))
                {
                    ShowErrorMessage("Lütfən bütün sahələri doldurun");
                    return;
                }

                // App_Data qovluğunun mövcudluğunu yoxla
                string appDataPath = Server.MapPath("~/App_Data");
                if (!Directory.Exists(appDataPath))
                {
                    try
                    {
                        Directory.CreateDirectory(appDataPath);
                    }
                    catch (Exception ex)
                    {
                        ShowErrorMessage("Qovluq yaratma xətası: " + ex.Message);
                        return;
                    }
                }

                // İstifadəçilər JSON faylının yolunu al
                string filePath = Path.Combine(appDataPath, "users.json");

                // JSON faylından mövcud istifadəçiləri oxu
                List<User> usersList = ReadUsersFromFile(filePath);

                // LINQ istifadə edərək istifadəçi adının mövcudluğunu yoxla
                User existingUser = usersList.FirstOrDefault(u => u.Username == username);

                if (existingUser != null)
                {
                    ShowErrorMessage("Bu istifadəçi adı artıq mövcuddur. Başqa bir ad seçin.");
                    return;
                }

                // Yeni istifadəçi düzəlt
                User newUser = new User
                {
                    Username = username,
                    Email = email,
                    Password = password
                };

                // Yeni istifadəçini siyahıya əlavə et
                usersList.Add(newUser);

                // Yenilənmiş siyahını JSON faylına sax
                SaveUsersToFile(filePath, usersList);

                // TextBoxları təmizlə
                UsernameTextBox.Text = "";
                EmailTextBox.Text = "";
                PasswordTextBox.Text = "";

                // Uğur mesajını göstər
                ShowSuccessMessage("Qeydiyyat uğurlu oldu! İndi <a href='Login.aspx'>daxil ola bilərsiniz</a>.");
            }
            catch (Exception ex)
            {
                ShowErrorMessage("Xəta baş verdi: " + ex.Message);
            }
        }

        // JSON faylından istifadəçiləri oxu
        private List<User> ReadUsersFromFile(string filePath)
        {
            try
            {
                // Fayl mövcud deyilsə, boş siyahı ilə yaratılsın
                if (!File.Exists(filePath))
                {
                    try
                    {
                        File.WriteAllText(filePath, "[]");
                    }
                    catch (Exception ex)
                    {
                        // Fayl yaratma başarısız olsa, boş siyahı qaytar
                        return new List<User>();
                    }
                    return new List<User>();
                }

                // Fayl məzmununu oxu
                string json = File.ReadAllText(filePath);

                // Fayl boş olarsa, boş siyahı qaytar
                if (string.IsNullOrWhiteSpace(json) || json.Trim() == "[]")
                {
                    return new List<User>();
                }

                // JSON-u List<User>-ə çevir
                JavaScriptSerializer serializer = new JavaScriptSerializer();
                List<User> users = serializer.Deserialize<List<User>>(json);

                return users ?? new List<User>();
            }
            catch (Exception ex)
            {
                // Xəta halında boş siyahı qaytar
                return new List<User>();
            }
        }

        // İstifadəçiləri JSON faylına sax
        private void SaveUsersToFile(string filePath, List<User> usersList)
        {
            try
            {
                // Siyahını JSON-a çevir
                JavaScriptSerializer serializer = new JavaScriptSerializer();
                string json = serializer.Serialize(usersList);

                // Faylın yerləşdiyi qovluğun mövcudluğunu təmin et
                string directory = Path.GetDirectoryName(filePath);
                if (!Directory.Exists(directory))
                {
                    Directory.CreateDirectory(directory);
                }

                // Əgər fayl mövcuddursa və readonly atributu varsa, onu normal et
                if (File.Exists(filePath))
                {
                    try
                    {
                        FileAttributes attrs = File.GetAttributes(filePath);
                        if ((attrs & FileAttributes.ReadOnly) == FileAttributes.ReadOnly)
                        {
                            attrs = attrs & ~FileAttributes.ReadOnly;
                            File.SetAttributes(filePath, attrs);
                        }
                    }
                    catch
                    {
                        // Atributları dəyişmək mümkün olmayanda davam et və cəhd et
                    }
                }

                // Faylı təhlükəsiz şəkildə açıb yaz
                byte[] bytes = System.Text.Encoding.UTF8.GetBytes(json);
                using (FileStream fs = new FileStream(filePath, FileMode.Create, FileAccess.Write, FileShare.None))
                {
                    fs.Write(bytes, 0, bytes.Length);
                    fs.Flush();
                }
            }
            catch (UnauthorizedAccessException uaEx)
            {
                // Konkret icazə xətası üçün daha aydın mesaj ver
                throw new Exception("İstifadəçiləri saxlamaqda xəta: Yola erişim engellendi. Server icazələrini yoxlayın. (" + uaEx.Message + ")");
            }
            catch (Exception ex)
            {
                throw new Exception("İstifadəçiləri saxlamaqda xəta: " + ex.Message);
            }
        }

        // Uğur mesajını göstər
        private void ShowSuccessMessage(string message)
        {
            MessageLabel.Text = message;
            MessageLabel.CssClass = "message success";
            MessageLabel.Visible = true;
        }

        // Xəta mesajını göstər
        private void ShowErrorMessage(string message)
        {
            MessageLabel.Text = message;
            MessageLabel.CssClass = "message error";
            MessageLabel.Visible = true;
        }
    }
}
