<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="Students.aspx.cs" Inherits="MiniStudentManagementSystem.Students" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>Tələbələr - Mini Tələbə İdarəetmə Sistemi</title>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 900px;
            margin: 30px auto;
            background-color: white;
            padding: 30px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #ddd;
            padding-bottom: 15px;
        }
        h1 {
            color: #333;
            margin: 0;
        }
        .logout-link a {
            color: #dc3545;
            text-decoration: none;
            font-weight: bold;
        }
        .logout-link a:hover {
            text-decoration: underline;
        }
        .add-student {
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 5px;
            margin-bottom: 30px;
            border-left: 4px solid #28a745;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-weight: bold;
        }
        input[type="text"] {
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 3px;
            font-size: 14px;
            width: 200px;
        }
        input[type="button"] {
            padding: 8px 20px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-weight: bold;
        }
        input[type="button"]:hover {
            background-color: #218838;
        }
        .message {
            margin-bottom: 20px;
            padding: 12px;
            border-radius: 3px;
            text-align: center;
        }
        .success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        .error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        table th {
            background-color: #007bff;
            color: white;
            padding: 12px;
            text-align: left;
        }
        table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }
        table tr:hover {
            background-color: #f5f5f5;
        }
        a {
            color: #007bff;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .no-data {
            text-align: center;
            padding: 20px;
            color: #666;
        }
    </style>
</head>
<body>
    <form id="form1" runat="server">
        <div class="container">
            <div class="header">
                <h1>Tələbə İdarəetməsi</h1>
                <div class="logout-link">
                    Xoş gəldiniz, <strong><asp:Label ID="UsernameLabel" runat="server"></asp:Label></strong>
                    | <a href="Logout.aspx">Çıxış</a>
                </div>
            </div>

            <asp:Label ID="MessageLabel" runat="server" Visible="false"></asp:Label>

            <div class="add-student">
                <h3>Yeni Tələbə Əlavə Edin</h3>
                <div class="form-group">
                    <label for="NameTextBox">Ad:</label>
                    <asp:TextBox ID="NameTextBox" runat="server"></asp:TextBox>
                </div>

                <div class="form-group">
                    <label for="SurnameTextBox">Soyad:</label>
                    <asp:TextBox ID="SurnameTextBox" runat="server"></asp:TextBox>
                </div>

                <div class="form-group">
                    <label for="StudentNumberTextBox">Tələbə Nömrəsi:</label>
                    <asp:TextBox ID="StudentNumberTextBox" runat="server"></asp:TextBox>
                </div>

                <div>
                    <asp:Button ID="AddButton" runat="server" Text="Tələbə Əlavə Et" OnClick="AddButton_Click" />
                </div>
            </div>

            <h3>Tələbələr Siyahısı</h3>
            <asp:GridView ID="StudentsGridView" runat="server"
                AutoGenerateColumns="false"
                OnRowEditing="StudentsGridView_RowEditing"
                OnRowUpdating="StudentsGridView_RowUpdating"
                OnRowCancelingEdit="StudentsGridView_RowCancelingEdit"
                OnRowDeleting="StudentsGridView_RowDeleting">
                <Columns>
                    <asp:CommandField ShowEditButton="true" ShowDeleteButton="true" ButtonType="Link"
                        EditText="Redaktə Et" UpdateText="Yenilə" CancelText="Ləğv et" DeleteText="Sil" />
                    <asp:BoundField DataField="Name" HeaderText="Ad" />
                    <asp:BoundField DataField="Surname" HeaderText="Soyad" />
                    <asp:BoundField DataField="StudentNumber" HeaderText="Tələbə Nömrəsi" />
                </Columns>
            </asp:GridView>
        </div>
    </form>
</body>
</html>
